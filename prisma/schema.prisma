generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(cuid())
  name            String?
  email           String     @unique
  password        String
  themePreference String     @default("cherry-blossom")
  reminderDays    Int        @default(1)
  timezone        String     @default("UTC")
  avatarUrl       String?
  ownBirthday     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  birthdays       Birthday[]
}

model Birthday {
  id             String           @id @default(cuid())
  name           String
  date           DateTime
  notes          String?
  relationship   String?
  interests      String?
  zodiacSign     String?
  userId         String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  imageUrl       String?
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  giftIdeas      GiftIdea[]
  messageHistory MessageHistory[]
}

model GiftIdea {
  id         String   @id @default(cuid())
  birthdayId String
  title      String
  url        String?
  price      Float?
  status     String   @default("idea")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  birthday   Birthday @relation(fields: [birthdayId], references: [id], onDelete: Cascade)
}

model MessageHistory {
  id         String   @id @default(cuid())
  birthdayId String
  year       Int
  message    String
  giftGiven  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  birthday   Birthday @relation(fields: [birthdayId], references: [id], onDelete: Cascade)
}
